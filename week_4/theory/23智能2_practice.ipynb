   "source": [
    "import seaborn as sns\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def sinplot(flip=2):\n",
    "    x = np.linspace(0, 20, 50)\n",
    "    for i in range(1, 5):\n",
    "        plt.plot(x, np.cos(x + i * 0.8) * (9 - 2*i) * flip)\n",
    "sinplot()\n",
    "\n"
   ],
